Algoritmo Tablasmultiplicar
	
	//Objetivo: Mostrar en pantalla las tablas de multiplicar del 1 al 10
	Escribir sin saltar "Tablas de multiplicar del 1 al 10";
	Escribir "";
	
	//Declarar variables
	Definir tabla, i, j Como Entero;
	Definir volver Como Caracter;
	Dimension tabla[11,11];
	
	Repetir
		// Iniciar variable
		volver <- 'r';
		
		//Condicional para que muestre solo las tablas del 1 al 10
		Para i <- 1 Hasta 10 Hacer
			//Condicional para la operación
			Para j <- 1 Hasta 10 Hacer
				tabla[i, j] <- i * j;
			FinPara
		FinPara
		
		Escribir "";
		Escribir Sin Saltar "___ TABLAS DE MULTIPLICAR ___";
		Escribir "";
		Para i<-1 Hasta 10 Hacer
			Escribir "";
			Escribir Sin Saltar "Tabla del ", i, ":";
			Escribir "";
			Para j<-1 Hasta 10 Hacer
				Escribir i, " x ", j, " = ", tabla[i,j];
			FinPara
			Escribir "";
		FinPara
		
		//Volver al menú
		Escribir "";
		Escribir Sin Saltar "Para repetir digite <r>, para salir cualquier tecla: ";
		Leer volver;
	Hasta Que (volver <> 'r')
FinAlgoritmo
